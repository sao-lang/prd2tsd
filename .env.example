# === Application ===
APP_NAME=prd2tsd
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === PostgreSQL (块 A 启用) ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/prd2tsd
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# === Redis (块 B 起启用) ===
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=10

# === MinIO (块 D 起启用) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prd2tsd
MINIO_SECURE=false

# === Neo4j (块 B 起启用) ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_DATABASE=neo4j

# === Model Config - LLM (DeepSeek) ===
MODEL_CONFIG__LLM__DEEPSEEK__API_KEY=sk-your-deepseek-key
MODEL_CONFIG__LLM__DEEPSEEK__BASE_URL=https://api.deepseek.com/v1
MODEL_CONFIG__LLM__DEEPSEEK__DEFAULT_MODEL=deepseek-chat

# === Model Config - LLM (OpenAI Fallback) ===
MODEL_CONFIG__LLM__OPENAI__API_KEY=sk-your-openai-key
MODEL_CONFIG__LLM__OPENAI__BASE_URL=https://api.openai.com/v1
MODEL_CONFIG__LLM__OPENAI__DEFAULT_MODEL=gpt-4o-mini

# === Model Config - Embedding ===
MODEL_CONFIG__EMBEDDING__OPENAI__API_KEY=sk-your-openai-key
MODEL_CONFIG__EMBEDDING__OPENAI__BASE_URL=https://api.openai.com/v1
MODEL_CONFIG__EMBEDDING__OPENAI__DEFAULT_MODEL=text-embedding-3-small

# === Model Config - Rerank ===
MODEL_CONFIG__RERANK__COHERE__API_KEY=coh-your-cohere-key
MODEL_CONFIG__RERANK__COHERE__BASE_URL=https://api.cohere.com/v1
MODEL_CONFIG__RERANK__COHERE__DEFAULT_MODEL=rerank-english-v3.0

# === Model Config - Judge ===
MODEL_CONFIG__JUDGE__OPENAI__API_KEY=sk-your-openai-key
MODEL_CONFIG__JUDGE__OPENAI__BASE_URL=https://api.openai.com/v1
MODEL_CONFIG__JUDGE__OPENAI__DEFAULT_MODEL=gpt-4o-mini

# === Model Config - Vision ===
MODEL_CONFIG__VISION__OPENAI__API_KEY=sk-your-openai-key
MODEL_CONFIG__VISION__OPENAI__BASE_URL=https://api.openai.com/v1
MODEL_CONFIG__VISION__OPENAI__DEFAULT_MODEL=gpt-4o

# === Model Routing Rules ===
MODEL_ROUTING__ANALYSIS_REQUIREMENT__TYPE=llm
MODEL_ROUTING__ANALYSIS_REQUIREMENT__PROVIDER=deepseek
MODEL_ROUTING__ANALYSIS_REQUIREMENT__MODEL=deepseek-chat

MODEL_ROUTING__ANALYSIS_CONSTRAINT__TYPE=llm
MODEL_ROUTING__ANALYSIS_CONSTRAINT__PROVIDER=deepseek
MODEL_ROUTING__ANALYSIS_CONSTRAINT__MODEL=deepseek-chat

MODEL_ROUTING__PLANNING_ARCHITECTURE__TYPE=llm
MODEL_ROUTING__PLANNING_ARCHITECTURE__PROVIDER=deepseek
MODEL_ROUTING__PLANNING_ARCHITECTURE__MODEL=deepseek-chat

MODEL_ROUTING__EVALUATION_SCORING__TYPE=judge
MODEL_ROUTING__EVALUATION_SCORING__PROVIDER=openai
MODEL_ROUTING__EVALUATION_SCORING__MODEL=gpt-4o-mini

MODEL_ROUTING__EMBEDDING__TYPE=embedding
MODEL_ROUTING__EMBEDDING__PROVIDER=openai
MODEL_ROUTING__EMBEDDING__MODEL=text-embedding-3-small

MODEL_ROUTING__RERANK__TYPE=rerank
MODEL_ROUTING__RERANK__PROVIDER=cohere
MODEL_ROUTING__RERANK__MODEL=rerank-english-v3.0
